# ─── Copier ce fichier en .env et remplir les valeurs ───────────────────────
# cp .env.example .env

# Clé API LLM (OpenAI ou NVIDIA NIM)
OPENAI_API_KEY=nvapi-...

# Endpoint LLM — OpenAI par défaut, NVIDIA NIM si tu utilises build.nvidia.com
# OpenAI  : https://api.openai.com/v1  (défaut si variable absente)
# NVIDIA  : https://integrate.api.nvidia.com/v1
LLM_BASE_URL=https://integrate.api.nvidia.com/v1

# Modèle LLM utilisé pour l'enrichissement des commandes
# OpenAI : gpt-4o-mini
# NVIDIA : moonshotai/kimi-k2.5
GPT_MODEL=moonshotai/kimi-k2.5

# Chemin vers le binaire whisper.cpp (adapter selon ta compilation)
WHISPER_BIN=~/whisper.cpp/main

# URL du serveur central (votre PC ou cloud)
CENTRAL_SERVER_URL=http://192.168.1.100:8000

# Modèle Ollama local sur le Raspberry Pi
OLLAMA_MODEL=llama3.2
OLLAMA_URL=http://localhost:11434

# Whisper : taille du modèle (tiny | base | small | medium)
WHISPER_MODEL=small

# Logiciel de facturation cible (jobber | quickbooks | custom_url)
FACTURATION_TYPE=jobber

# ─── Jobber ────────────────────────────────────────────────────────────────────
# Pas de credentials ici — login manuel via MFA :
#   python tools/jobber_setup_session.py
# La session est sauvegardée dans storage/jobber_session.json

# Afficher le navigateur pendant l'automation (true=visible, false=headless)
PLAYWRIGHT_HEADLESS=false

# Intervalle de synchro cloud (en secondes)
SYNC_INTERVAL=30

# Niveau de log (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

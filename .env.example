# ─── Copier ce fichier en .env et remplir les valeurs ───────────────────────
# cp .env.example .env

# Clé API OpenAI (GPT-5.4 ou gpt-4o selon disponibilité)
OPENAI_API_KEY=sk-...

# URL du serveur central (votre PC ou cloud)
CENTRAL_SERVER_URL=http://192.168.1.100:8000

# Modèle Ollama local sur le Raspberry Pi
OLLAMA_MODEL=llama3.2
OLLAMA_URL=http://localhost:11434

# Whisper : taille du modèle (tiny | base | small | medium)
WHISPER_MODEL=small

# Logiciel de facturation cible (quickbooks | sage | custom_url)
FACTURATION_TYPE=custom_url
FACTURATION_URL=http://localhost:3000

# Identifiants facturation (si besoin)
FACTURATION_USER=admin
FACTURATION_PASS=motdepasse

# Intervalle de synchro cloud (en secondes)
SYNC_INTERVAL=30

# Niveau de log (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
